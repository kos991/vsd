# dae gateway configuration template.
# Add your subscriptions or nodes before enabling dae at boot.
# This template follows the common daed split model: local/private/CN direct,
# non-CN and unmatched traffic through the proxy group, with DNS split first.

global {
  log_level: info
  tproxy_port: 12345
  tproxy_port_protect: true
  so_mark_from_dae: 0
  lan_interface: eth0
  wan_interface: auto
  auto_config_kernel_parameter: true
  dial_mode: domain
}

subscription {
  # Example:
  # main: 'https-file://example.com/subscription'
}

node {
  # Example:
  # my_socks: 'socks5://127.0.0.1:1080'
}

group {
  proxy {
    # Change to fixed(0) if you want the first node/subscription node only.
    policy: min_moving_avg
  }
}

dns {
  upstream {
    alidns: 'udp://dns.alidns.com:53'
    dnspod: 'udp://119.29.29.29:53'
    googledns: 'tcp+udp://dns.google:53'
  }
  routing {
    request {
      # Keep mainland/CN DNS local, use trusted remote DNS for everything else.
      qname(geosite:cn) -> alidns
      qtype(https) -> reject
      fallback: googledns
    }
    response {
      # Accept trusted remote DNS answers. If a non-CN domain returns private IPs,
      # treat it as pollution and retry with Google DNS.
      upstream(googledns) -> accept
      ip(geoip:private) && !qname(geosite:cn) -> googledns
      fallback: accept
    }
  }
}

routing {
  # Do not capture DNS failover service traffic, otherwise DNS can loop.
  pname(mini-ppdns) -> must_direct
  pname(NetworkManager) -> direct
  dip(224.0.0.0/3, 'ff00::/8') -> direct
  dip(geoip:private) -> direct

  # Optional: block QUIC/H3 to reduce memory/CPU pressure on small gateways.
  l4proto(udp) && dport(443) -> block

  # Common daed split: mainland by IP/domain direct, non-CN by domain proxy.
  dip(geoip:cn) -> direct
  domain(geosite:cn) -> direct
  domain(geosite:geolocation-!cn) -> proxy

  # Put your custom high-priority rules above fallback.
  # domain(full: example.com) -> direct
  # sip(192.168.1.100) -> direct
  # mac('02:42:ac:11:00:02') -> proxy

  fallback: proxy
}
