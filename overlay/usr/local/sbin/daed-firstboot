#!/bin/sh
set -eu

done_file="/etc/dae-gateway-firstboot.done"
tcp_conf="/etc/sysctl.d/92-tcp-tuning.conf"
one_arm_conf="/etc/sysctl.d/91-one-arm-gateway.conf"
DAED_FIRSTBOOT_PID=""

prompt_msg() {
    printf '%s' "$*" >&2
}

prompt_secret() {
    label="$1"
    while :; do
        prompt_msg "$label: "
        stty -echo 2>/dev/null || true
        if ! read -r first; then
            stty echo 2>/dev/null || true
            printf '\n' >&2
            return 1
        fi
        stty echo 2>/dev/null || true
        printf '\n' >&2
        prompt_msg "再次输入 $label: "
        stty -echo 2>/dev/null || true
        if ! read -r second; then
            stty echo 2>/dev/null || true
            printf '\n' >&2
            return 1
        fi
        stty echo 2>/dev/null || true
        printf '\n' >&2
        if [ "$first" = "$second" ] && [ -n "$first" ]; then
            printf '%s\n' "$first"
            return 0
        fi
        printf '两次输入不一致或为空，请重新输入。\n' >&2
    done
}

strong_password() {
    password="$1"
    [ "${#password}" -ge 6 ] || return 1
    printf '%s' "$password" | grep -q '[A-Za-z]' || return 1
    printf '%s' "$password" | grep -q '[0-9]' || return 1
}

prompt_strong_secret() {
    label="$1"
    while :; do
        password="$(prompt_secret "$label")"
        if strong_password "$password"; then
            printf '%s\n' "$password"
            return 0
        fi
        printf '密码强度不足：至少 6 位，并且必须同时包含字母和数字。\n' >&2
    done
}

prompt_default() {
    label="$1"
    default="$2"
    prompt_msg "$label [$default]: "
    read -r value || value=""
    value="$(printf '%s' "$value" | tr -d '\r')"
    [ -n "$value" ] || value="$default"
    printf '%s\n' "$value"
}

is_uint() {
    case "$1" in
        ''|*[!0-9]*) return 1 ;;
        *) return 0 ;;
    esac
}

prompt_uint_default() {
    label="$1"
    default="$2"
    while :; do
        value="$(prompt_default "$label" "$default")"
        if is_uint "$value" && [ "$value" -gt 0 ]; then
            printf '%s\n' "$value"
            return 0
        fi
        printf '%s 必须是正整数。\n' "$label" >&2
    done
}

write_one_arm_gateway_sysctl() {
    cat >"$one_arm_conf" <<'EOF'
net.ipv4.ip_forward=1
net.ipv6.conf.all.forwarding=1
net.ipv4.conf.all.rp_filter=0
net.ipv4.conf.default.rp_filter=0
net.ipv4.conf.all.send_redirects=0
net.ipv4.conf.default.send_redirects=0
net.ipv4.conf.all.accept_redirects=0
net.ipv4.conf.default.accept_redirects=0
EOF
}

write_tcp_tuning() {
    bandwidth_mbps="$1"
    latency_ms="$2"
    memory_mb="$3"

    bdp_bytes=$(( bandwidth_mbps * 1000000 / 8 * latency_ms / 1000 ))
    min_buf=$(( 4 * 1024 * 1024 ))
    max_buf=$(( bdp_bytes * 4 ))
    [ "$max_buf" -ge "$min_buf" ] || max_buf="$min_buf"
    memory_cap=$(( memory_mb * 1024 * 1024 / 4 ))
    [ "$max_buf" -le "$memory_cap" ] || max_buf="$memory_cap"
    [ "$max_buf" -ge "$min_buf" ] || max_buf="$min_buf"
    default_buf=$(( max_buf / 2 ))

    cat >"$tcp_conf" <<EOF
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr
net.core.rmem_max=${max_buf}
net.core.wmem_max=${max_buf}
net.ipv4.tcp_rmem=4096 87380 ${max_buf}
net.ipv4.tcp_wmem=4096 65536 ${max_buf}
net.ipv4.tcp_mtu_probing=1
net.ipv4.tcp_fastopen=3
net.ipv4.tcp_slow_start_after_idle=0
net.core.netdev_max_backlog=250000
net.core.somaxconn=4096
# Derived from bandwidth=${bandwidth_mbps}Mbps latency=${latency_ms}ms memory=${memory_mb}MB default_buffer=${default_buf}
EOF

    modprobe tcp_bbr >/dev/null 2>&1 || true
    modprobe sch_fq >/dev/null 2>&1 || true
}

configure_root_password() {
    password="$(prompt_strong_secret '新的 root 密码')"
    printf 'root:%s\n' "$password" | chpasswd
    passwd -u root >/dev/null 2>&1 || true
}

configure_daed_credentials() {
    username="$(prompt_default 'daed 管理员用户名' 'admin')"
    password="$(prompt_strong_secret 'daed 管理员密码')"
    umask 077
    cat >/etc/daed/firstboot-admin.env <<EOF
DAED_ADMIN_USERNAME='${username}'
DAED_ADMIN_PASSWORD='${password}'
EOF
    printf '已保存 daed 首次启动管理员凭据提示到 /etc/daed/firstboot-admin.env。\n'
    DAED_ADMIN_USERNAME="$username"
    DAED_ADMIN_PASSWORD="$password"
}

json_escape() {
    printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

daed_api_ready() {
    curl -fsS --connect-timeout 1 --max-time 2 \
        -H 'Content-Type: application/json' \
        --data '{"query":"query { numberUsers }"}' \
        http://127.0.0.1:2023/graphql >/dev/null 2>&1
}

wait_daed_graphql() {
    i=0
    while [ "$i" -lt 30 ]; do
        if daed_api_ready; then
            return 0
        fi
        i=$((i + 1))
        sleep 1
    done
    return 1
}

start_firstboot_daed() {
    if daed_api_ready; then
        return 0
    fi

    if [ ! -x /usr/bin/daed ]; then
        printf '/usr/bin/daed 不存在或不可执行。\n'
        return 1
    fi

    mkdir -p /var/log/daed
    printf '正在启动临时 daed API，用于完成首次初始化'
    XDG_DATA_HOME=/etc /usr/bin/daed run -c /etc/daed/ --api-only \
        >/var/log/daed/firstboot-daed.log \
        2>/var/log/daed/firstboot-daed.err &
    DAED_FIRSTBOOT_PID="$!"

    i=0
    while [ "$i" -lt 30 ]; do
        if daed_api_ready; then
            printf '\n'
            return 0
        fi
        if ! kill -0 "$DAED_FIRSTBOOT_PID" 2>/dev/null; then
            printf '\ndaed 在 API 就绪前已退出。\n'
            tail -n 40 /var/log/daed/firstboot-daed.err 2>/dev/null || true
            return 1
        fi
        printf '.'
        i=$((i + 1))
        sleep 1
    done

    printf '\ndaed API 在 30 秒内未就绪。\n'
    tail -n 40 /var/log/daed/firstboot-daed.err 2>/dev/null || true
    return 1
}

stop_firstboot_daed() {
    if [ -n "${DAED_FIRSTBOOT_PID:-}" ]; then
        if kill -0 "$DAED_FIRSTBOOT_PID" 2>/dev/null; then
            kill "$DAED_FIRSTBOOT_PID" 2>/dev/null || true
            i=0
            while kill -0 "$DAED_FIRSTBOOT_PID" 2>/dev/null && [ "$i" -lt 5 ]; do
                sleep 1
                i=$((i + 1))
            done
            if kill -0 "$DAED_FIRSTBOOT_PID" 2>/dev/null; then
                kill -KILL "$DAED_FIRSTBOOT_PID" 2>/dev/null || true
            fi
        fi
        wait "$DAED_FIRSTBOOT_PID" 2>/dev/null || true
    fi
    DAED_FIRSTBOOT_PID=""
}

cleanup_firstboot() {
    stop_firstboot_daed
}

trap cleanup_firstboot EXIT INT TERM

create_daed_admin() {
    username="${DAED_ADMIN_USERNAME:-}"
    password="${DAED_ADMIN_PASSWORD:-}"
    [ -n "$username" ] && [ -n "$password" ] || return 0

    printf '正在创建 daed 首个管理员用户...\n'

    if ! start_firstboot_daed; then
        printf 'daed API 未就绪。请在仪表盘初始化页面使用已保存的凭据。\n'
        stop_firstboot_daed
        return 0
    fi

    if ! wait_daed_graphql; then
        printf 'daed API 未就绪。请在仪表盘初始化页面使用已保存的凭据。\n'
        stop_firstboot_daed
        return 0
    fi

    user_json="$(json_escape "$username")"
    pass_json="$(json_escape "$password")"
    payload='{"query":"mutation CreateUser($username: String!, $password: String!) { createUser(username: $username, password: $password) }","variables":{"username":"'"$user_json"'","password":"'"$pass_json"'"}}'

    response="$(curl -fsS --connect-timeout 2 --max-time 10 -H 'Content-Type: application/json' --data "$payload" http://127.0.0.1:2023/graphql 2>/tmp/daed-firstboot-create-user.err || true)"
    if printf '%s' "$response" | grep -q '"errors"'; then
        printf 'daed createUser 返回错误。如果用户未创建，请在仪表盘初始化页面继续处理。\n'
        printf '%s\n' "$response" >/etc/daed/firstboot-create-user.response
        chmod 600 /etc/daed/firstboot-create-user.response
        stop_firstboot_daed
        return 0
    fi

    if printf '%s' "$response" | grep -Eq '"createUser"[[:space:]]*:[[:space:]]*"[^" ]+"'; then
        printf '已通过 GraphQL createUser 创建 daed 管理员用户。\n'
    else
        printf 'daed createUser 未确认成功。如果无法登录，请在仪表盘初始化页面继续处理。\n'
        printf '%s\n' "$response" >/etc/daed/firstboot-create-user.response
        chmod 600 /etc/daed/firstboot-create-user.response
    fi
    stop_firstboot_daed
}

configure_tcp_prompt() {
    printf '是否启用 BBR TCP 优化？[Y/n]: '
    read -r answer || answer=""
    answer="$(printf '%s' "$answer" | tr -d '\r')"
    case "$answer" in
        n|N|no|NO) return 0 ;;
    esac

    bandwidth="$(prompt_uint_default '线路带宽 Mbps' '1000')"
    latency="$(prompt_uint_default '典型延迟 ms' '100')"
    memory="$(awk '/MemTotal:/ { printf "%d", $2 / 1024 }' /proc/meminfo 2>/dev/null || printf '1024')"
    memory="$(prompt_uint_default '内存大小 MB' "$memory")"
    write_tcp_tuning "$bandwidth" "$latency" "$memory"
    sysctl -p "$tcp_conf" >/dev/null 2>&1 || true
}

run_firstboot() {
    if [ -f "$done_file" ]; then
        printf '首次启动向导已经完成。如需重新运行，请执行 "daed-firstboot reset"。\n'
        return 0
    fi

    cat <<'EOF'

daed Alpine Gateway 首次启动向导

本向导会在仪表盘启动前设置 root 登录密码、daed 管理员凭据、网关 sysctl，
并可选择启用 BBR/fq TCP 优化。

EOF

    configure_root_password
    configure_daed_credentials
    write_one_arm_gateway_sysctl
    configure_tcp_prompt
    sysctl --system >/dev/null 2>&1 || true
    create_daed_admin

    date -u '+%Y-%m-%dT%H:%M:%SZ' >"$done_file"
    chmod 600 "$done_file"

    printf '\n首次启动向导已完成。\n'
    printf '打开 daed 仪表盘：http://<网关IP>:2023\n'
    printf '连通性确认后，客户端网关和 DNS 可以指向这台 VM 的地址。\n'
}

reset_firstboot() {
    rm -f "$done_file"
    printf '首次启动完成标记已删除。请执行 "daed-firstboot run" 或重启。\n'
}

case "${1:-run}" in
    run) run_firstboot ;;
    reset) reset_firstboot ;;
    write-tcp) write_tcp_tuning "${2:-1000}" "${3:-100}" "${4:-1024}" ;;
    *) printf '用法：daed-firstboot [run|reset|write-tcp]\n'; exit 1 ;;
esac
