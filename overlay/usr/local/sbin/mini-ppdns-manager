#!/bin/sh
set -eu

service_name="mini-ppdns"
binary_path="/usr/sbin/mini-ppdns"
service_path="/etc/init.d/mini-ppdns"
config_path="/etc/mini-ppdns.ini"
log_files="/var/log/mini-ppdns/mini-ppdns.log /var/log/mini-ppdns/mini-ppdns.err"
default_dns="223.5.5.5:53 119.29.29.29:53"
default_fallback="1.1.1.1:53 8.8.8.8:53"
default_listen="0.0.0.0:53"

is_installed() { [ -x "$binary_path" ]; }
has_service() { [ -x "$service_path" ]; }
has_config() { [ -f "$config_path" ]; }

version_text() {
    if is_installed; then
        "$binary_path" --version 2>/dev/null | head -1 || ls -l "$binary_path" | awk '{print "installed, size " $5 " bytes"}'
    else
        printf 'not installed'
    fi
}

service_state() {
    if has_service; then
        rc-service "$service_name" status >/dev/null 2>&1 && printf 'running' || printf 'stopped'
    else
        printf 'not installed'
    fi
}

boot_state() {
    rc-update show default 2>/dev/null | grep -q "[[:space:]]${service_name}[[:space:]]" && printf 'enabled' || printf 'disabled'
}

upstream_url() {
    ref="${MINI_PPDNS_REF:-release}"
    case "$(uname -m)" in
        x86_64) asset="mini-ppdns_x86_64" ;;
        aarch64) asset="mini-ppdns_aarch64" ;;
        armv7l) asset="mini-ppdns_armv7l" ;;
        armv6l) asset="mini-ppdns_armv6l" ;;
        i686) asset="mini-ppdns_i686" ;;
        *) printf 'unsupported'; return ;;
    esac
    printf 'https://raw.githubusercontent.com/kkkgo/mini-ppdns/%s/%s' "$ref" "$asset"
}

status_view() {
    printf '\nmini-ppdns status\n\n'
    is_installed && printf 'Install: installed\n' || printf 'Install: missing\n'
    printf 'Version: %s\n' "$(version_text)"
    printf 'Service: %s\n' "$(service_state)"
    printf 'Boot: %s\n' "$(boot_state)"
    has_config && printf 'Config: ready\n' || printf 'Config: missing\n'
}

details_view() {
    status_view
    printf '\nDetails\n'
    printf 'Binary: %s %s\n' "$binary_path" "$(is_installed && printf ok || printf missing)"
    printf 'OpenRC: %s %s\n' "$service_path" "$(has_service && printf ok || printf missing)"
    printf 'Config: %s %s\n' "$config_path" "$(has_config && printf ok || printf missing)"
    printf 'Logs: %s\n' "$log_files"
}

updates_view() {
    status_view
    printf '\nUpdate check\n'
    url="$(upstream_url)"
    if [ "$url" = "unsupported" ]; then
        printf 'Upstream: unsupported architecture %s\n' "$(uname -m)"
    elif curl -fsI "$url" >/dev/null 2>&1; then
        printf 'Upstream: available at %s\n' "${MINI_PPDNS_REF:-release}"
    else
        printf 'Upstream: unable to check\n'
    fi
    printf 'Action: check only, no binary replacement\n'
}

normalize_endpoint() {
    endpoint="$1"
    case "$endpoint" in
        *:*) printf '%s\n' "$endpoint" ;;
        *) printf '%s:53\n' "$endpoint" ;;
    esac
}

normalize_list() {
    for endpoint in $1; do
        normalize_endpoint "$endpoint"
    done
}

write_config() {
    dns_list="$1"
    fallback_list="$2"
    listen_addr="$3"

    if [ -f "$config_path" ]; then
        cp "$config_path" "${config_path}.bak"
    fi

    {
        printf '# mini-ppdns configuration generated by mini-ppdns-manager.\n'
        printf '\n[dns]\n'
        normalize_list "$dns_list"
        printf '\n[fall]\n'
        normalize_list "$fallback_list"
        printf '\n[listen]\n'
        normalize_endpoint "$listen_addr"
        printf '\n[adv]\n'
        printf 'qtime=250\n'
        printf 'aaaa=noerror\n'
        printf 'lite=yes\n'
        printf 'boguspriv=1\n'
        printf '\n[hosts]\n'
        printf '# 10.10.10.53 paopao.dns\n'
        printf '\n[hook]\n'
        printf '# exec="curl -o /dev/null -s -w %%{http_code} http://www.gstatic.com/generate_204"\n'
    } >"$config_path"
}

show_config() {
    if [ -f "$config_path" ]; then
        sed -n '1,120p' "$config_path"
    else
        printf 'Config file is missing: %s\n' "$config_path"
    fi
}

restart_prompt() {
    printf 'Restart mini-ppdns now? [y/N]: '
    read -r answer || return 0
    answer="$(printf '%s' "$answer" | tr -d '\r')"
    case "$answer" in
        y|Y|yes|YES) rc-service mini-ppdns restart ;;
        *) printf 'Skipped restart.\n' ;;
    esac
}

manual_config() {
    printf 'Mainland DNS endpoints, separated by spaces [%s]: ' "$default_dns"
    read -r dns_list || return 0
    dns_list="$(printf '%s' "$dns_list" | tr -d '\r')"
    [ -n "$dns_list" ] || dns_list="$default_dns"

    printf 'Fallback DNS endpoints, separated by spaces [%s]: ' "$default_fallback"
    read -r fallback_list || return 0
    fallback_list="$(printf '%s' "$fallback_list" | tr -d '\r')"
    [ -n "$fallback_list" ] || fallback_list="$default_fallback"

    printf 'Listen address [%s]: ' "$default_listen"
    read -r listen_addr || return 0
    listen_addr="$(printf '%s' "$listen_addr" | tr -d '\r')"
    [ -n "$listen_addr" ] || listen_addr="$default_listen"

    write_config "$dns_list" "$fallback_list" "$listen_addr"
    printf 'Config written to %s\n' "$config_path"
    restart_prompt
}

recommended_config() {
    write_config "$default_dns" "$default_fallback" "$default_listen"
    printf 'Recommended DNS config written to %s\n' "$config_path"
    restart_prompt
}

configure_dns() {
    while :; do
        cat <<'EOF'

mini-ppdns DNS setup

1) Use recommended DNS
2) Enter DNS manually
3) Show current config
0) Back

EOF
        printf 'Choose: '
        read -r choice || exit 0
        choice="$(printf '%s' "$choice" | tr -d '\r')"
        case "$choice" in
            1) recommended_config ;;
            2) manual_config ;;
            3) show_config ;;
            0) return 0 ;;
            *) printf 'Unknown choice: %s\n' "$choice" ;;
        esac
        printf '\nPress Enter to continue...'
        read -r _ || exit 0
    done
}

menu() {
    while :; do
        status_view
        cat <<'EOF'

1) Start mini-ppdns
2) Stop mini-ppdns
3) Restart mini-ppdns
4) Follow logs
5) Check updates
6) Details
7) Configure DNS
0) Back

EOF
        printf 'Choose: '
        read -r choice || exit 0
        choice="$(printf '%s' "$choice" | tr -d '\r')"
        case "$choice" in
            1) rc-service mini-ppdns start ;;
            2) rc-service mini-ppdns stop || true ;;
            3) rc-service mini-ppdns restart ;;
            4) tail -n 80 -f $log_files ;;
            5) updates_view ;;
            6) details_view ;;
            7) configure_dns ;;
            0) exit 0 ;;
            *) printf 'Unknown choice: %s\n' "$choice" ;;
        esac
        if [ "$choice" != "4" ]; then
            printf '\nPress Enter to continue...'
            read -r _ || exit 0
        fi
    done
}

case "${1:-menu}" in
    menu) menu ;;
    status) status_view ;;
    start) rc-service mini-ppdns start ;;
    stop) rc-service mini-ppdns stop || true ;;
    restart) rc-service mini-ppdns restart ;;
    logs) tail -n 80 -f $log_files ;;
    updates) updates_view ;;
    details) details_view ;;
    configure) configure_dns ;;
    *) printf 'Usage: mini-ppdns-manager [menu|status|start|stop|restart|logs|updates|details|configure]\n'; exit 1 ;;
esac
