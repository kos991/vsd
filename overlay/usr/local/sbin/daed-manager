#!/bin/sh
set -eu

service_name="daed"
binary_path="/usr/bin/daed"
service_path="/etc/init.d/daed"
config_path="/etc/daed"
log_files="/var/log/daed/daed.log /var/log/daed/daed.err"

is_installed() { [ -x "$binary_path" ]; }
has_service() { [ -x "$service_path" ]; }
has_config() { [ -d "$config_path" ]; }

version_text() {
    if is_installed; then
        "$binary_path" --version 2>/dev/null | head -1 || printf 'installed'
    else
        printf 'not installed'
    fi
}

service_state() {
    if has_service; then
        rc-service "$service_name" status >/dev/null 2>&1 && printf 'running' || printf 'stopped'
    else
        printf 'not installed'
    fi
}

boot_state() {
    rc-update show default 2>/dev/null | grep -q "[[:space:]]${service_name}[[:space:]]" && printf 'enabled' || printf 'disabled'
}

latest_daed_tag() {
    curl -fsSL 'https://api.github.com/repos/daeuniverse/daed/releases?per_page=20' \
        | awk '
          /"tag_name":/ {
            tag=$0
            sub(/^.*"tag_name":[[:space:]]*"/, "", tag)
            sub(/".*$/, "", tag)
          }
          /"name":[[:space:]]*"daed-linux-/ {
            if (tag ~ /^v[0-9]/) {
              print tag
              exit
            }
          }'
}

status_view() {
    printf '\ndaed status\n\n'
    is_installed && printf 'Install: installed\n' || printf 'Install: missing\n'
    printf 'Version: %s\n' "$(version_text)"
    printf 'Service: %s\n' "$(service_state)"
    printf 'Boot: %s\n' "$(boot_state)"
    has_config && printf 'Config: ready\n' || printf 'Config: missing\n'
    printf 'Dashboard: http://<gateway-ip>:2023\n'
}

details_view() {
    status_view
    printf '\nDetails\n'
    printf 'Binary: %s %s\n' "$binary_path" "$(is_installed && printf ok || printf missing)"
    printf 'OpenRC: %s %s\n' "$service_path" "$(has_service && printf ok || printf missing)"
    printf 'Config dir: %s %s\n' "$config_path" "$(has_config && printf ok || printf missing)"
    printf 'GeoIP: /etc/daed/geoip.dat %s\n' "$([ -r /etc/daed/geoip.dat ] && printf ok || printf missing)"
    printf 'Geosite: /etc/daed/geosite.dat %s\n' "$([ -r /etc/daed/geosite.dat ] && printf ok || printf missing)"
    printf 'Logs: %s\n' "$log_files"
}

start_service() {
    if has_service && [ "$(service_state)" = "stopped" ]; then
        rc-service "$service_name" zap >/dev/null 2>&1 || true
    fi
    rc-service "$service_name" start
}

restart_service() {
    if has_service && [ "$(service_state)" = "stopped" ]; then
        rc-service "$service_name" zap >/dev/null 2>&1 || true
        rc-service "$service_name" start
    else
        rc-service "$service_name" restart
    fi
}

updates_view() {
    status_view
    printf '\nUpdate check\n'
    printf 'Latest daed: '
    if tag="$(latest_daed_tag 2>/dev/null)" && [ -n "$tag" ]; then
        printf '%s\n' "$tag"
    else
        printf 'unable to check\n'
    fi
    printf 'Action: check only, no binary replacement\n'
}

menu() {
    while :; do
        status_view
        cat <<'EOF'

1) Start daed
2) Stop daed
3) Restart daed
4) Follow logs
5) Check updates
6) Details
7) Reset firstboot wizard
0) Back

EOF
        printf 'Choose: '
        read -r choice || exit 0
        choice="$(printf '%s' "$choice" | tr -d '\r')"
        case "$choice" in
            1) start_service ;;
            2) rc-service daed stop || true ;;
            3) restart_service ;;
            4) tail -n 80 -f $log_files ;;
            5) updates_view ;;
            6) details_view ;;
            7) daed-firstboot reset ;;
            0) exit 0 ;;
            *) printf 'Unknown choice: %s\n' "$choice" ;;
        esac
        if [ "$choice" != "4" ]; then
            printf '\nPress Enter to continue...'
            read -r _ || exit 0
        fi
    done
}

case "${1:-menu}" in
    menu) menu ;;
    status) status_view ;;
    start) start_service ;;
    stop) rc-service daed stop || true ;;
    restart) restart_service ;;
    logs) tail -n 80 -f $log_files ;;
    updates) updates_view ;;
    details) details_view ;;
    reset-firstboot) daed-firstboot reset ;;
    *) printf 'Usage: daed-manager [menu|status|start|stop|restart|logs|updates|details|reset-firstboot]\n'; exit 1 ;;
esac
