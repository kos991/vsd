#!/bin/sh
set -eu

service_name="dae"
binary_path="/usr/sbin/dae"
service_path="/etc/init.d/dae"
config_path="/etc/dae/config.dae"
log_files="/var/log/dae/dae.log /var/log/dae/dae.err"

is_installed() { [ -x "$binary_path" ]; }
has_service() { [ -x "$service_path" ]; }
has_config() { [ -f "$config_path" ]; }

version_text() {
    if is_installed; then
        "$binary_path" --version 2>/dev/null | head -1 || printf 'installed'
    else
        printf 'not installed'
    fi
}

service_state() {
    if has_service; then
        rc-service "$service_name" status >/dev/null 2>&1 && printf 'running' || printf 'stopped'
    else
        printf 'not installed'
    fi
}

boot_state() {
    rc-update show default 2>/dev/null | grep -q "[[:space:]]${service_name}[[:space:]]" && printf 'enabled' || printf 'disabled'
}

latest_dae_tag() {
    curl -fsSL https://api.github.com/repos/daeuniverse/dae/releases/latest \
        | sed -n 's/.*"tag_name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' \
        | head -1
}

status_view() {
    printf '\ndae status\n\n'
    is_installed && printf 'Install: installed\n' || printf 'Install: missing\n'
    printf 'Version: %s\n' "$(version_text)"
    printf 'Service: %s\n' "$(service_state)"
    printf 'Boot: %s\n' "$(boot_state)"
    has_config && printf 'Config: ready\n' || printf 'Config: missing\n'
}

details_view() {
    status_view
    printf '\nDetails\n'
    printf 'Binary: %s %s\n' "$binary_path" "$(is_installed && printf ok || printf missing)"
    printf 'OpenRC: %s %s\n' "$service_path" "$(has_service && printf ok || printf missing)"
    printf 'Config: %s %s\n' "$config_path" "$(has_config && printf ok || printf missing)"
    printf 'Logs: %s\n' "$log_files"
}

updates_view() {
    status_view
    printf '\nUpdate check\n'
    printf 'Latest dae: '
    if tag="$(latest_dae_tag 2>/dev/null)" && [ -n "$tag" ]; then
        printf '%s\n' "$tag"
    else
        printf 'unable to check\n'
    fi
    printf 'Action: check only, no binary replacement\n'
}

menu() {
    while :; do
        status_view
        cat <<'EOF'

1) Start dae
2) Stop dae
3) Restart dae
4) Follow logs
5) Check updates
6) Details
0) Back

EOF
        printf 'Choose: '
        read -r choice || exit 0
        choice="$(printf '%s' "$choice" | tr -d '\r')"
        case "$choice" in
            1) rc-service dae start ;;
            2) rc-service dae stop || true ;;
            3) rc-service dae restart ;;
            4) tail -n 80 -f $log_files ;;
            5) updates_view ;;
            6) details_view ;;
            0) exit 0 ;;
            *) printf 'Unknown choice: %s\n' "$choice" ;;
        esac
        if [ "$choice" != "4" ]; then
            printf '\nPress Enter to continue...'
            read -r _ || exit 0
        fi
    done
}

case "${1:-menu}" in
    menu) menu ;;
    status) status_view ;;
    start) rc-service dae start ;;
    stop) rc-service dae stop || true ;;
    restart) rc-service dae restart ;;
    logs) tail -n 80 -f $log_files ;;
    updates) updates_view ;;
    details) details_view ;;
    *) printf 'Usage: dae-manager [menu|status|start|stop|restart|logs|updates|details]\n'; exit 1 ;;
esac
