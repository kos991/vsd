#!/bin/sh
set -eu

fail() {
    echo "ERROR: $*" >&2
    exit 1
}

mountpoint -q /sys/fs/bpf || fail "/sys/fs/bpf is not mounted. Check fstab bpffs entry."
mountpoint -q /sys/fs/cgroup || fail "/sys/fs/cgroup is not mounted. Check fstab cgroup2 entry."

if ! grep -qw bpf /proc/filesystems; then
    fail "kernel does not expose bpf filesystem support"
fi

if ! grep -qw cgroup2 /proc/filesystems; then
    fail "kernel does not expose cgroup2 filesystem support"
fi

if [ ! -r /sys/kernel/btf/vmlinux ]; then
    fail "/sys/kernel/btf/vmlinux is missing. Install a kernel with BTF support for daed eBPF programs."
fi

if [ "$(cat /proc/sys/net/ipv4/ip_forward)" != "1" ]; then
    fail "net.ipv4.ip_forward must be 1"
fi

if command -v bpftool >/dev/null 2>&1; then
    bpftool feature probe kernel >/tmp/check-ebpf.log 2>&1 || {
        cat /tmp/check-ebpf.log >&2
        fail "bpftool feature probe kernel failed"
    }
else
    fail "bpftool is not installed"
fi

echo "eBPF preflight passed"
