#!/bin/sh
set -eu

run_action() {
    case "$1" in
        1) daed-manager ;;
        2) dae-gateway-manager ebpf ;;
        3) dae-gateway-manager status ;;
        4) qos-manager ;;
        0) exit 0 ;;
        *) printf 'Unknown choice: %s\n' "$1" ;;
    esac
}

while :; do
    cat <<'EOF'

daed Alpine Gateway

1) daed manager
2) eBPF check
3) Gateway overview
4) QoS / CAKE
0) Exit

EOF
    printf 'Choose: '
    read -r choice || exit 0
    choice="$(printf '%s' "$choice" | tr -d '\r')"
    run_action "$choice"
    if [ "$choice" != "1" ]; then
        printf '\nPress Enter to continue...'
        read -r _ || exit 0
    fi
done
