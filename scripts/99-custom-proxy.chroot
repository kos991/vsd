#!/bin/sh
set -e

chmod +x \
  /usr/local/bin/daed \
  /usr/local/bin/mosdns \
  /opt/custom-services/scripts/late-bind.sh \
  /opt/custom-services/scripts/dns-hijack.sh \
  /opt/custom-services/scripts/geosite-update.sh

ln -sf /opt/custom-services/geo/geoip.dat /opt/custom-services/daed/geoip.dat
ln -sf /opt/custom-services/geo/geosite.dat /opt/custom-services/daed/geosite.dat

cp -f /opt/custom-services/daed/config.dae /opt/custom-services/daed/config.dae.template
cp -f /opt/custom-services/mosdns/config.yaml /opt/custom-services/mosdns/config.yaml.template

# late-bind renders the LAN IP/subnet first, then starts the stack. Enabling the
# individual services here races against placeholder rendering on first boot.
systemctl enable late-bind.service
