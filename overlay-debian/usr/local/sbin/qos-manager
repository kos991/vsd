#!/bin/sh
set -eu

config_path="/etc/dae-gateway-qos.conf"

load_config() {
    ENABLED=no
    WAN_IFACE=""
    DOWNLOAD_MBIT=""
    UPLOAD_MBIT=""
    if [ -f "$config_path" ]; then
        . "$config_path"
    fi
    return 0
}

apply_qos() {
    load_config
    [ "${ENABLED:-no}" = "yes" ] || exit 0
    [ -n "${WAN_IFACE:-}" ] || exit 0
    modprobe ifb numifbs=1 >/dev/null 2>&1 || true
    ip link add ifb0 type ifb 2>/dev/null || true
    ip link set ifb0 up
    tc qdisc replace dev "$WAN_IFACE" root cake bandwidth "${UPLOAD_MBIT}mbit" besteffort
    tc qdisc replace dev "$WAN_IFACE" ingress
    tc filter replace dev "$WAN_IFACE" parent ffff: protocol all matchall action mirred egress redirect dev ifb0
    tc qdisc replace dev ifb0 root cake bandwidth "${DOWNLOAD_MBIT}mbit" besteffort
}

status_view() {
    load_config
    printf '\nQoS / CAKE\n\n'
    printf 'Enabled: %s\n' "${ENABLED:-no}"
    printf 'WAN: %s\n' "${WAN_IFACE:-unset}"
    printf 'Download: %s mbit\n' "${DOWNLOAD_MBIT:-unset}"
    printf 'Upload: %s mbit\n' "${UPLOAD_MBIT:-unset}"
}

configure() {
    printf 'WAN interface: '
    read -r WAN_IFACE
    printf 'Download mbit: '
    read -r DOWNLOAD_MBIT
    printf 'Upload mbit: '
    read -r UPLOAD_MBIT
    cat >"$config_path" <<EOF
ENABLED=yes
WAN_IFACE='$WAN_IFACE'
DOWNLOAD_MBIT='$DOWNLOAD_MBIT'
UPLOAD_MBIT='$UPLOAD_MBIT'
EOF
    systemctl enable dae-qos.service >/dev/null 2>&1 || true
    apply_qos
}

menu() {
    while :; do
        status_view
        cat <<'EOF'

1) Configure and apply
2) Apply current config
3) Disable
0) Back

EOF
        printf 'Choose: '
        read -r choice || exit 0
        case "$(printf '%s' "$choice" | tr -d '\r')" in
            1) configure ;;
            2) apply_qos ;;
            3) sed -i "s/^ENABLED=.*/ENABLED=no/" "$config_path" 2>/dev/null || true ;;
            0) exit 0 ;;
            *) printf 'Unknown choice: %s\n' "$choice" ;;
        esac
    done
}

case "${1:-menu}" in
    menu) menu ;;
    status) status_view ;;
    apply) apply_qos ;;
    configure) configure ;;
    *) printf 'Usage: qos-manager [menu|status|apply|configure]\n'; exit 1 ;;
esac
