#!/bin/sh
set -eu

db_path="/etc/daed/wing.db"
link_rule="pname(dnscrypt-proxy) -> proxy"
old_link_rule="pname(dnscrypt-proxy, mosdns, unbound) -> proxy"
udp443_rule="l4proto(udp) && dport(443) -> block"

python_apply() {
    python3 - "$db_path" "$link_rule" "$old_link_rule" "$udp443_rule" <<'PY'
import re
import shutil
import sqlite3
import sys
import time

db_path = sys.argv[1]
link_rule = sys.argv[2]
old_link_rule = sys.argv[3]
udp443_rule = sys.argv[4]
google_youtube_rule = """domain(
    suffix:youtube.com,
    suffix:youtu.be,
    suffix:googlevideo.com,
    suffix:ytimg.com,
    suffix:ggpht.com,
    suffix:gvt1.com,
    suffix:gvt2.com,
    suffix:google.com,
    suffix:googleapis.com,
    suffix:gstatic.com,
    suffix:googleusercontent.com,
    suffix:google-analytics.com,
    suffix:googleadservices.com
) -> proxy"""

con = sqlite3.connect(db_path)
cur = con.cursor()
row = cur.execute(
    "select id, routing, version from routings where selected = 1 order by id limit 1"
).fetchone()
if row is None:
    raise SystemExit("selected daed routing is missing")

routing_id, routing, version = row
if "fallback:" not in routing:
    raise SystemExit("selected daed routing does not look valid")

config_row = cur.execute(
    "select id, global, version from configs where selected = 1 order by id limit 1"
).fetchone()

backup = f"{db_path}.bak-paopaodns-link-{int(time.time())}"
shutil.copy2(db_path, backup)

changed = False
lines = routing.splitlines()
lines = [line for line in lines if line.strip() != old_link_rule]
insert_at = 1 if lines and lines[0].strip() == "routing {" else 0
if udp443_rule not in lines:
    lines.insert(insert_at, udp443_rule)
    insert_at += 1
    changed = True
if link_rule not in lines:
    lines.insert(insert_at, link_rule)
    changed = True
new_routing = "\n".join(lines)

if "suffix:googlevideo.com" not in new_routing or "suffix:gstatic.com" not in new_routing:
    for marker in ("dip(geoip:private) -> direct", "dip(geoip:cn) -> direct", "domain(geosite:cn) -> direct", "fallback:"):
        if marker in new_routing:
            new_routing = new_routing.replace(marker, google_youtube_rule + "\n" + marker, 1)
            changed = True
            break

if new_routing != routing:
    cur.execute(
        "update routings set routing = ?, version = ? where id = ?",
        (new_routing, int(version or 0) + 1, routing_id),
    )

if config_row is not None:
    config_id, global_config, config_version = config_row
    new_global_config = re.sub(
        r'fallback_resolver:"[^"]+"',
        'fallback_resolver:"127.0.0.1:53"',
        global_config,
    )
    if new_global_config != global_config:
        cur.execute(
            "update configs set global = ?, version = ? where id = ?",
            (new_global_config, int(config_version or 0) + 1, config_id),
        )
        changed = True
con.commit()
if changed:
    print(f"PaoPaoDNS linked to dae routing. Backup: {backup}")
else:
    print("PaoPaoDNS is already linked to dae routing.")
PY
}

python_status() {
    python3 - "$db_path" "$link_rule" "$old_link_rule" "$udp443_rule" <<'PY'
import sqlite3
import sys

db_path = sys.argv[1]
link_rule = sys.argv[2]
old_link_rule = sys.argv[3]
udp443_rule = sys.argv[4]

con = sqlite3.connect(f"file:{db_path}?mode=ro", uri=True)
cur = con.cursor()
row = cur.execute(
    "select id, name, routing from routings where selected = 1 order by id limit 1"
).fetchone()
if row is None:
    print("Link: missing selected daed routing")
    raise SystemExit(1)

routing_id, name, routing = row
print("dae <-> PaoPaoDNS link")
print(f"Routing: {name} (id {routing_id})")
print(f"Rule: {link_rule}")
print("PaoPaoDNS: linked" if link_rule in routing else "PaoPaoDNS: not linked")
print("UDP/443: blocked" if udp443_rule in routing else "UDP/443: not blocked")
print("Google/YouTube: proxy" if "suffix:googlevideo.com" in routing and "suffix:gstatic.com" in routing else "Google/YouTube: missing")
if old_link_rule in routing:
    print("Warning: old broad rule is still present")
config_row = cur.execute(
    "select global from configs where selected = 1 order by id limit 1"
).fetchone()
if config_row is not None:
    fallback = "unknown"
    for line in config_row[0].splitlines():
        if "fallback_resolver" in line:
            fallback = line.strip()
            break
    print(f"Fallback resolver: {fallback}")
PY
}

python_show() {
    python3 - "$db_path" <<'PY'
import sqlite3
import sys

db_path = sys.argv[1]
con = sqlite3.connect(f"file:{db_path}?mode=ro", uri=True)
cur = con.cursor()
row = cur.execute(
    "select routing from routings where selected = 1 order by id limit 1"
).fetchone()
if row is None:
    raise SystemExit("selected daed routing is missing")
print(row[0])
PY
}

require_db() {
    [ -f "$db_path" ] || {
        printf 'Missing daed database: %s\n' "$db_path" >&2
        exit 1
    }
}

case "${1:-status}" in
    status)
        require_db
        python_status
        ;;
    apply|link)
        require_db
        python_apply
        systemctl restart daed.service >/dev/null 2>&1 || true
        ;;
    show)
        require_db
        python_show
        ;;
    *)
        printf 'Usage: dae-paopaodns-link [status|apply|show]\n' >&2
        exit 1
        ;;
esac
