#!/bin/sh
set -eu

done_file="/etc/dae-gateway-firstboot.done"

prompt_secret() {
    label="$1"
    while :; do
        printf '%s: ' "$label" >/dev/tty
        stty -echo </dev/tty 2>/dev/null || true
        read -r first </dev/tty || first=""
        stty echo </dev/tty 2>/dev/null || true
        printf '\n' >/dev/tty
        printf 'Confirm %s: ' "$label" >/dev/tty
        stty -echo </dev/tty 2>/dev/null || true
        read -r second </dev/tty || second=""
        stty echo </dev/tty 2>/dev/null || true
        printf '\n' >/dev/tty
        if [ -n "$first" ] && [ "$first" = "$second" ]; then
            printf '%s\n' "$first"
            return 0
        fi
        printf 'The two values did not match or were empty. Try again.\n' >/dev/tty
    done
}

if [ -f "$done_file" ]; then
    exit 0
fi

cat >/dev/tty <<'EOF'

Debian daed Gateway firstboot

Set the root password. Create the daed administrator later in the daed dashboard.

EOF

password="$(prompt_secret 'new root password')"
printf 'root:%s\n' "$password" | chpasswd
passwd -u root >/dev/null 2>&1 || true

date -u '+%Y-%m-%dT%H:%M:%SZ' >"$done_file"
chmod 600 "$done_file"

cat >/dev/tty <<'EOF'

Firstboot completed.
Open daed dashboard: http://<gateway-ip>:2023

EOF
