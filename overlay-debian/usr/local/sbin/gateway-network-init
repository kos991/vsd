#!/bin/sh
set -eu

log() {
    printf '%s\n' "$*"
}

load_net_modules() {
    for module in vmxnet3 e1000 e1000e virtio_net; do
        modprobe "$module" >/dev/null 2>&1 || true
    done
}

is_real_iface() {
    iface="$1"
    case "$iface" in
        lo|dae0|docker*|veth*|br-*|tun*|tap*|wg*|zt*|ifb*|dummy*)
            return 1
            ;;
    esac
    [ -e "/sys/class/net/$iface/device" ] || return 1
    return 0
}

default_route_iface() {
    ip -4 route show default 2>/dev/null | awk '
        NR == 1 {
            for (i = 1; i <= NF; i++) {
                if ($i == "dev") {
                    print $(i + 1)
                    exit
                }
            }
        }
    '
}

first_real_iface() {
    for path in /sys/class/net/*; do
        iface="${path##*/}"
        [ -d "$path" ] || continue
        is_real_iface "$iface" || continue
        printf '%s\n' "$iface"
        return 0
    done
    return 1
}

gateway_iface() {
    iface="$(default_route_iface || true)"
    if [ -n "$iface" ] && is_real_iface "$iface"; then
        printf '%s\n' "$iface"
        return 0
    fi
    first_real_iface
}

iface_has_ipv4() {
    ip -4 addr show dev "$1" 2>/dev/null | grep -q 'inet '
}

link_cidr_for_iface() {
    ip -4 route show dev "$1" scope link 2>/dev/null | awk '$1 != "default" { print $1; exit }'
}

configure_gateway_forwarding() {
    iface="$1"
    lan_cidr="$(link_cidr_for_iface "$iface")"

    sysctl -w net.ipv4.ip_forward=1 >/dev/null 2>&1 || true
    sysctl -w net.ipv4.conf.all.rp_filter=0 >/dev/null 2>&1 || true
    sysctl -w net.ipv4.conf.default.rp_filter=0 >/dev/null 2>&1 || true
    sysctl -w "net.ipv4.conf.${iface}.rp_filter=0" >/dev/null 2>&1 || true
    sysctl -w net.ipv4.conf.all.send_redirects=0 >/dev/null 2>&1 || true
    sysctl -w net.ipv4.conf.default.send_redirects=0 >/dev/null 2>&1 || true
    sysctl -w "net.ipv4.conf.${iface}.send_redirects=0" >/dev/null 2>&1 || true
    sysctl -w net.ipv4.conf.all.accept_redirects=0 >/dev/null 2>&1 || true
    sysctl -w net.ipv4.conf.default.accept_redirects=0 >/dev/null 2>&1 || true
    sysctl -w "net.ipv4.conf.${iface}.accept_redirects=0" >/dev/null 2>&1 || true

    [ -n "$lan_cidr" ] || return 0
    command -v iptables >/dev/null 2>&1 || return 0

    iptables -t nat -C POSTROUTING -s "$lan_cidr" ! -d "$lan_cidr" -o "$iface" -j MASQUERADE >/dev/null 2>&1 \
        || iptables -t nat -A POSTROUTING -s "$lan_cidr" ! -d "$lan_cidr" -o "$iface" -j MASQUERADE
}

main() {
    load_net_modules

    iface="$(gateway_iface || true)"
    if [ -z "$iface" ]; then
        log "No non-loopback network interface found."
        return 0
    fi

    ip link set "$iface" up >/dev/null 2>&1 || true
    if iface_has_ipv4 "$iface"; then
        log "Gateway forwarding ready on $iface."
        configure_gateway_forwarding "$iface"
    else
        log "No IPv4 address on $iface yet."
    fi
}

main "$@"
