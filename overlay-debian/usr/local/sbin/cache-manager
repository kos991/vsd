#!/bin/sh
set -eu

service_name="gateway-cache-warm.service"
timer_name="gateway-cache-warm.timer"
sites_path="/etc/dae-gateway/cache-sites.conf"

status_view() {
    printf '\nGateway cache warm\n\n'
    printf 'Config: %s\n' "$sites_path"
    if [ -f "$sites_path" ]; then
        printf 'DNS targets: %s\n' "$(grep -Ec '^[[:space:]]*dns:' "$sites_path" || true)"
        printf 'Warm targets: %s\n' "$(grep -Ec '^[[:space:]]*warm:' "$sites_path" || true)"
    else
        printf 'DNS targets: missing config\n'
        printf 'Warm targets: missing config\n'
    fi
    systemctl --no-pager --plain status "$timer_name" "$service_name" 2>/dev/null || true
}

run_now() {
    [ -f "$sites_path" ] || {
        printf 'Missing cache site list: %s\n' "$sites_path" >&2
        exit 1
    }

    started_at="$(date -Iseconds 2>/dev/null || date)"
    printf 'Cache warm started: %s\n' "$started_at"

    while IFS= read -r line || [ -n "$line" ]; do
        line="${line%%#*}"
        line="$(printf '%s' "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
        [ -n "$line" ] || continue
        case "$line" in
            dns:*)
                host="${line#dns:}"
                printf 'dns %s ' "$host"
                if getent ahostsv4 "$host" >/dev/null 2>&1; then
                    printf 'ok\n'
                else
                    printf 'miss\n'
                fi
                ;;
            warm:http://*|warm:https://*)
                url="${line#warm:}"
                case "$url" in
                    */generate_204) ;;
                    *)
                        printf 'warm %s skipped\n' "$url"
                        continue
                        ;;
                esac
                printf 'warm %s ' "$url"
                if curl -4 -k -L -o /dev/null -sS --connect-timeout 3 --max-time 8 "$url"; then
                    printf 'ok\n'
                else
                    printf 'miss\n'
                fi
                ;;
        esac
    done <"$sites_path"

    printf 'Cache warm finished: %s\n' "$(date -Iseconds 2>/dev/null || date)"
}

show_sites() {
    if [ -f "$sites_path" ]; then
        sed -n '1,220p' "$sites_path"
    else
        printf 'Missing cache site list: %s\n' "$sites_path" >&2
        exit 1
    fi
}

logs_view() {
    journalctl -u gateway-cache-warm.service -u gateway-cache-warm.timer --no-pager -n 120
}

menu() {
    while :; do
        status_view
        cat <<'EOF'

1) Start timer
2) Stop timer
3) Restart timer
4) Run now
5) Logs
6) Sites
0) Back

EOF
        printf 'Choose: '
        read -r choice || exit 0
        case "$(printf '%s' "$choice" | tr -d '\r')" in
            1) systemctl start gateway-cache-warm.timer ;;
            2) systemctl stop gateway-cache-warm.timer ;;
            3) systemctl restart gateway-cache-warm.timer ;;
            4) run_now ;;
            5) logs_view ;;
            6) show_sites ;;
            0) exit 0 ;;
            *) printf 'Unknown choice: %s\n' "$choice" ;;
        esac
        printf '\nPress Enter to continue...'
        read -r _ || exit 0
    done
}

case "${1:-menu}" in
    menu) menu ;;
    status) status_view ;;
    start) systemctl start gateway-cache-warm.timer ;;
    stop) systemctl stop gateway-cache-warm.timer ;;
    restart) systemctl restart gateway-cache-warm.timer ;;
    logs) logs_view ;;
    run-now) run_now ;;
    sites) show_sites ;;
    *) printf 'Usage: cache-manager [menu|status|start|stop|restart|logs|run-now|sites]\n'; exit 1 ;;
esac
