#!/bin/sh
set -eu

while :; do
    cat <<'EOF'

Debian daed Gateway

1) daed manager
2) PaoPaoDNS manager
3) eBPF check
4) Gateway overview
5) QoS / CAKE
6) mini-ppdns fallback
7) Link PaoPaoDNS with dae
8) Cache warm manager
9) DNS leak guard
0) Exit

EOF
    printf 'Choose: '
    read -r choice || exit 0
    case "$(printf '%s' "$choice" | tr -d '\r')" in
        1) daed-manager ;;
        2) paopaodns-manager ;;
        3) check-ebpf ;;
        4) dae-gateway-manager status ;;
        5) qos-manager ;;
        6) mini-ppdns-manager ;;
        7) dae-paopaodns-link status; printf '\nApply link now? [y/N]: '; read -r yn || exit 0; case "$(printf '%s' "$yn" | tr -d '\r')" in y|Y) dae-paopaodns-link apply ;; esac ;;
        8) cache-manager ;;
        9) dns-leak-guard status; printf '\nSeal DNS leak now? [y/N]: '; read -r yn || exit 0; case "$(printf '%s' "$yn" | tr -d '\r')" in y|Y) dns-leak-guard apply ;; esac ;;
        0) exit 0 ;;
        *) printf 'Unknown choice: %s\n' "$choice" ;;
    esac
    printf '\nPress Enter to continue...'
    read -r _ || exit 0
done
