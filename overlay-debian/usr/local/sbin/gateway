#!/bin/sh
set -eu

while :; do
    cat <<'EOF'

Debian daed Gateway

1) daed manager
2) PaoPaoDNS manager
3) eBPF check
4) Gateway overview
5) QoS / CAKE
6) mini-ppdns fallback
0) Exit

EOF
    printf 'Choose: '
    read -r choice || exit 0
    case "$(printf '%s' "$choice" | tr -d '\r')" in
        1) daed-manager ;;
        2) paopaodns-manager ;;
        3) check-ebpf ;;
        4) dae-gateway-manager status ;;
        5) qos-manager ;;
        6) mini-ppdns-manager ;;
        0) exit 0 ;;
        *) printf 'Unknown choice: %s\n' "$choice" ;;
    esac
    printf '\nPress Enter to continue...'
    read -r _ || exit 0
done
